# Example environment file. Copy to ".env" (gitignored) and fill in your values.
# .env is loaded automatically by src/train.py and src/eval.py.
# Hydra references these in the YAML configs via ${oc.env:MY_VAR}.

# Where to store cached datasets, logs, and checkpoints.
SCRATCH_DIR="/home/user/my/system/path"

# Weights & Biases logging.
WANDB_PROJECT="autoregressive-boltzmann-generators"
# Leave WANDB_ENTITY unset to log to your default account, or set a team/username.
# WANDB_ENTITY="your-team-or-username"
